    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst ahora = new Date();\nconst ts = ahora.getTime();\nconst fecha = ahora.toLocaleDateString('es-ES');\nconst hora = ahora.toLocaleTimeString('es-ES', {hour:'2-digit', minute:'2-digit'});\nconst id_pedido = `ORD-${data.telegram_id.slice(-4)}-${ts.toString().slice(-6)}`;\n\n// Tomar carrito de accion.carrito o carrito_nuevo\nconst carrito = (data.accion?.carrito && data.accion.carrito.length > 0) \n  ? data.accion.carrito \n  : data.carrito_nuevo;\n\nconst detalles = carrito.map(i => `${i.nombre}x${i.cantidad}`).join(' + ');\nconst total = carrito.reduce((s, i) => s + (parseFloat(i.precio) * i.cantidad), 0).toFixed(2);\n\nreturn [{ json: { ...data, id_pedido, fecha, hora, detalles_pedido: detalles, total_nuevo: total, carrito_nuevo: carrito } }];"
      },
