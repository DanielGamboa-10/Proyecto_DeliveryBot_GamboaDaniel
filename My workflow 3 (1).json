    {
      "parameters": {
        "jsCode": "const body = $input.first().json;\nlet telegram_id, nombre, texto, tipo;\nif (body.callback_query) {\n  telegram_id = String(body.callback_query.from.id);\n  nombre = body.callback_query.from.first_name || 'Usuario';\n  texto = body.callback_query.data;\n  tipo = 'callback';\n} else if (body.message) {\n  telegram_id = String(body.message.from.id);\n  nombre = body.message.from.first_name || 'Usuario';\n  texto = body.message.text || '';\n  tipo = 'mensaje';\n}\nreturn [{ json: { telegram_id, nombre, texto: texto.trim(), tipo, timestamp: new Date().toISOString() } }];"
      },
