        "jsCode": "const pedidos = $input.all().map(i => i.json);\nconst hoy = new Date().toLocaleDateString('es-ES');\nconst pedidosHoy = pedidos.filter(p => p.fecha === hoy);\nif (pedidosHoy.length === 0) { return [{ json: { reporte: '📊 No hubo pedidos hoy.' } }]; }\nconst totalDia = pedidosHoy.reduce((sum, p) => sum + parseFloat(p.total_pago || 0), 0);\nconst conteoProductos = {};\npedidosHoy.forEach(p => { const items = (p.detalles_pedido || '').split(' + '); items.forEach(item => { const match = item.match(/^(.+?)x(\\d+)$/); if (match) { conteoProductos[match[1]] = (conteoProductos[match[1]] || 0) + parseInt(match[2]); } }); });\nconst estrella = Object.entries(conteoProductos).sort((a,b) => b[1]-a[1])[0];\nconst horasPedidos = {};\npedidosHoy.forEach(p => { const h = (p.hora||'').split(':')[0]; horasPedidos[h] = (horasPedidos[h]||0)+1; });\nconst horaPico = Object.entries(horasPedidos).sort((a,b)=>b[1]-a[1])[0];\nconst reporte = `📊 *REPORTE DIARIO DELIVERYBOT*\\n📅 ${hoy}\\n\\n🛒 Pedidos: ${pedidosHoy.length}\\n💰 Total: $${totalDia.toFixed(2)}\\n⭐ Estrella: ${estrella ? estrella[0]+' ('+estrella[1]+' uds)' : 'N/A'}\\n🕐 Hora pico: ${horaPico ? horaPico[0]+':00 ('+horaPico[1]+' pedidos)' : 'N/A'}\\n\\n📦 Detalle:\\n`+Object.entries(conteoProductos).map(([k,v])=>`  • ${k}: ${v}`).join('\\n');\nreturn [{ json: { reporte } }];"
      },
