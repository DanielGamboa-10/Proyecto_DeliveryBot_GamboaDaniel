    {
      "parameters": {
        "jsCode": "const input = $('Normalizar Input').first().json;\nconst sessionData = $input.first()?.json;\nlet pantalla_actual = 'INICIO';\nlet carrito_temporal = [];\nif (sessionData && sessionData.telegram_id) {\n  pantalla_actual = sessionData.pantalla_actual || 'INICIO';\n  try { carrito_temporal = JSON.parse(sessionData.carrito_temporal || '[]'); } catch(e) { carrito_temporal = []; }\n}\nreturn [{ json: { ...input, pantalla_actual, carrito_temporal, tiene_sesion: !!(sessionData && sessionData.telegram_id) } }];"
      },
