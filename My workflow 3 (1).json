      "parameters": {
        "jsCode": "const msg = $input.first().json;\nconst texto = msg.message?.text || '';\nconst admin_id = String(msg.message?.from?.id || '');\nconst chat_id = String(msg.message?.chat?.id || '');\nif (chat_id !== '-5178162213') { return [{ json: { valido: false, admin_id, error: 'Solo admins pueden cambiar estados.' } }]; }\nconst match = texto.match(/^\\/estado\\s+(ORD-\\S+)\\s+(.+)/);\nif (!match) { return [{ json: { valido: false, admin_id, error: 'Formato: /estado ORD-XXXX-XXXXXX Preparando' } }]; }\nconst estadosValidos = ['Recibido','Preparando','En camino','Entregado','Cancelado'];\nconst nuevoEstado = match[2].trim();\nif (!estadosValidos.includes(nuevoEstado)) { return [{ json: { valido: false, admin_id, error: `Estados válidos: ${estadosValidos.join(', ')}` } }]; }\nreturn [{ json: { valido: true, id_pedido: match[1], nuevo_estado: nuevoEstado, admin_id } }];"
